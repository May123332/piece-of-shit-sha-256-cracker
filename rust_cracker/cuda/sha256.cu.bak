#include <cuda_runtime.h>
#include <device_launch_parameters.h>
#include <stdint.h>

// SHA-256 Constants
__constant__ uint32_t K[64] = {
    0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5, 0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5,
    0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3, 0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174,
    0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc, 0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da,
    0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7, 0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967,
    0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13, 0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85,
    0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3, 0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070,
    0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5, 0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3,
    0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208, 0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2
};

// PTX Optimized Rotates (funnel shift)
#define ROR(x, n) (__funnelshift_r((x), (x), (n)))

// Logic
#define CH(x, y, z) (z ^ (x & (y ^ z)))
#define MAJ(x, y, z) ((x & y) | (z & (x | y)))

#define SIGMA0(x) (ROR(x, 2) ^ ROR(x, 13) ^ ROR(x, 22))
#define SIGMA1(x) (ROR(x, 6) ^ ROR(x, 11) ^ ROR(x, 25))
#define GAMMA0(x) (ROR(x, 7) ^ ROR(x, 18) ^ (x >> 3))
#define GAMMA1(x) (ROR(x, 17) ^ ROR(x, 19) ^ (x >> 10))

// Swap Endianness (Native PTX instruction)
#define SWAP(x) (__byte_perm((x), 0, 0x0123))

__device__ __forceinline__ void sha256_transform(uint32_t* state, const uint32_t* data) {
    uint32_t W[64];
    uint32_t a, b, c, d, e, f, g, h, t1, t2;

    // Load and Swap
    #pragma unroll
    for (int i = 0; i < 16; i++) W[i] = SWAP(data[i]);

    // Expand
    #pragma unroll
    for (int i = 16; i < 64; i++) W[i] = GAMMA1(W[i - 2]) + W[i - 7] + GAMMA0(W[i - 15]) + W[i - 16];

    a = state[0]; b = state[1]; c = state[2]; d = state[3];
    e = state[4]; f = state[5]; g = state[6]; h = state[7];

    #pragma unroll
    for (int i = 0; i < 64; i++) {
        t1 = h + SIGMA1(e) + CH(e, f, g) + K[i] + W[i];
        t2 = SIGMA0(a) + MAJ(a, b, c);
        h = g; g = f; f = e; e = d + t1; d = c; c = b; b = a; a = t1 + t2;
    }

    state[0] += a; state[1] += b; state[2] += c; state[3] += d;
    state[4] += e; state[5] += f; state[6] += g; state[7] += h;
}

extern "C" __global__ void brute_force_cuda(
    const uint8_t* charset, 
    uint64_t charset_len, 
    uint64_t start_offset, 
    uint32_t len,
    const uint32_t* target_hash, // 8 words
    uint32_t* result_found, 
    uint8_t* result_word
) {
    // Global ID
    uint64_t idx = blockIdx.x * blockDim.x + threadIdx.x;
    uint64_t abs_id = start_offset + idx;
    
    // We don't check bounds here, host manages batches precisely
    
    // 1. Generate Candidate
    uint8_t pass[64];
    uint64_t temp = abs_id;
    
    // Reverse base-N generation
    #pragma unroll
    for(int i = len - 1; i >= 0; i--) {
        pass[i] = charset[temp % charset_len];
        temp /= charset_len;
    }
    
    // 2. Prepare Buffer (Padding)
    // 32-bit aligned buffer for SHA256 input
    uint32_t buffer[16]; 
    #pragma unroll
    for(int i=0; i<16; i++) buffer[i] = 0;
    
    // Copy bytes to words (native endian)
    // We pack 4 chars into 1 uint
    // NOTE: SHA256 Transform expects Big Endian words, but our SWAP macro handles the flip.
    // So we just pack bytes naturally into the uint array.
    
    // Safe packing loop (assumes len < 56)
    for(int i=0; i<len; i++) {
        int word_idx = i / 4;
        int byte_idx = i % 4; // 0=MSB or LSB? 
        // We pack as: [0][1][2][3] -> 0x00010203
        // SWAP will turn it to 0x03020100 (Big Endian)
        // Wait, standard SHA256 input is a byte stream.
        // If memory is [c0, c1, c2, c3], reading as uint32 gives 0x03020100 on Little Endian.
        // SWAP converts 0x03020100 back to 0x00010203.
        // So we can just cast the uchar array pointer if aligned, or copy manually.
        
        // Manual copy for alignment safety
        // shift: (3 - byte_idx) * 8 for Big Endian logical construction?
        // No, let SWAP do the work. Just load bytes into memory order.
        
        // Little Endian Load simulation:
        // byte[0] goes to bits 0-7, byte[1] to 8-15...
        ((uint8_t*)buffer)[i] = pass[i];
    }
    
    // Append 0x80
    ((uint8_t*)buffer)[len] = 0x80;
    
    // Append Length (Big Endian 64-bit at end of block)
    // buffer[15] is lower 32 bits, buffer[14] is upper
    // But we need to write them so that SWAP makes them Big Endian correct?
    // SWAP reverses bytes in word.
    // If we want 0x000000L (L=bits), Big Endian stream is [00...00 L]
    // SWAP(w) -> w must be 0xL00...00 in register? No.
    // Let's just write raw bytes.
    uint64_t bit_len = len * 8;
    // Write Big Endian bytes to end
    uint8_t* byte_ptr = (uint8_t*)buffer;
    byte_ptr[63] = bit_len & 0xFF;
    byte_ptr[62] = (bit_len >> 8) & 0xFF;
    byte_ptr[61] = (bit_len >> 16) & 0xFF;
    byte_ptr[60] = (bit_len >> 24) & 0xFF;
    // 59..56 are 0 for lengths < 2^32 bits
    
    // 3. Hash
    uint32_t state[8] = {
        0x6a09e667, 0xbb67ae85, 0x3c6ef372, 0xa54ff53a,
        0x510e527f, 0x9b05688c, 0x1f83d9ab, 0x5be0cd19
    };
    
    sha256_transform(state, buffer);
    
    // 4. Check Match
    // Compare state[0..7] with target_hash[0..7]
    bool match = true;
    #pragma unroll
    for(int i=0; i<8; i++) {
        if (state[i] != target_hash[i]) match = false;
    }
    
    if (match) {
        if (atomicExch(result_found, 1) == 0) {
            for(int i=0; i<len; i++) result_word[i] = pass[i];
            result_word[len] = 0;
        }
    }
}

extern "C" void launch_brute_force_cuda(
    const uint8_t* charset, 
    uint64_t charset_len, 
    uint64_t start_offset, 
    uint32_t len,
    const uint32_t* target_hash, 
    uint32_t* result_found, 
    uint8_t* result_word,
    uint64_t batch_size,
    int blocks,
    int threads
) {
    brute_force_cuda<<<blocks, threads>>>(charset, charset_len, start_offset, len, target_hash, result_found, result_word);
    cudaDeviceSynchronize();
}
